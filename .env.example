# =================================
# AI MARKETING AGENT - ENVIRONMENT CONFIGURATION
# =================================

# ---------------------------------
# APPLICATION
# ---------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---------------------------------
# DATABASE
# ---------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_marketing_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_marketing_agent

# ---------------------------------
# REDIS
# ---------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------
# AI SERVICES
# ---------------------------------
# OpenAI (for GPT-4, DALL-E)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional, for advanced content)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Runway ML (for video generation)
RUNWAY_API_KEY=your_runway_api_key_here

# D-ID (for AI avatar videos)
DID_API_KEY=your_did_api_key_here

# ElevenLabs (for voiceovers)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Replicate (for additional AI models)
REPLICATE_API_TOKEN=your_replicate_token_here

# ---------------------------------
# SOCIAL MEDIA INTEGRATIONS
# ---------------------------------
# Meta (Facebook & Instagram)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

# TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# Google (Ads & YouTube)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id

# ---------------------------------
# STORAGE
# ---------------------------------
# AWS S3 (recommended)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-marketing-agent-media

# OR Cloudflare R2 (alternative)
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_ACCESS_KEY_ID=your_cloudflare_access_key
# CLOUDFLARE_SECRET_ACCESS_KEY=your_cloudflare_secret_key
# R2_BUCKET_NAME=ai-marketing-agent-media

# ---------------------------------
# AUTHENTICATION
# ---------------------------------
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------------------------------
# SECURITY
# ---------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ENABLED=true

# ---------------------------------
# MONITORING & LOGGING
# ---------------------------------
# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn_here

# LogTail / BetterStack
LOGTAIL_TOKEN=your_logtail_token_here

# ---------------------------------
# EMAIL (for notifications)
# ---------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@entradeltd.com

# ---------------------------------
# CELERY (task queue)
# ---------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------
# RATE LIMITING
# ---------------------------------
RATE_LIMIT_PER_MINUTE=60
MAX_VIDEO_GENERATION_PER_DAY=50

# ---------------------------------
# FEATURE FLAGS
# ---------------------------------
ENABLE_AUTO_POSTING=true
ENABLE_VIDEO_GENERATION=true
ENABLE_AI_AVATARS=true
ENABLE_ANALYTICS=true

# ---------------------------------
# BUSINESS SETTINGS
# ---------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,he
COMPANY_NAME=E N Trade LTD
COMPANY_WEBSITE=https://entradeltd.com

# ---------------------------------
# DEVELOPMENT
# ---------------------------------
DEBUG=true
LOG_LEVEL=INFO
